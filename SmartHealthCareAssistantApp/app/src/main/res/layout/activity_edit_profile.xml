<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/editProfile"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ffffff"
    tools:context=".edit_profile_activity">

    <ScrollView
        android:layout_marginTop="50dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:fitsSystemWindows="true"
        android:background="#ffffff">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center">

            <LinearLayout
                android:id="@+id/logo"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_centerHorizontal="true"
                android:background="@drawable/user_box_sec_two">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <!-- Profile Image -->
                    <ImageView
                        android:id="@+id/profilePic"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:alpha="0.7"
                        android:scaleType="centerCrop"
                        android:src="@drawable/user"
                        android:background="@drawable/user_box_sec_two"
                        android:clipToOutline="true"/>

                    <!-- Edit Icon -->
                    <ImageView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:layout_gravity="bottom|end"
                        android:layout_margin="4dp"
                        android:src="@drawable/edit_icon" />

                </FrameLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/logoText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/logo"
                android:layout_marginTop="10dp"
                android:layout_centerHorizontal="true"
                android:text="Edit Profile"
                android:textSize="25sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/statusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/logoText"
                android:layout_centerHorizontal="true"
                android:layout_marginBottom="16dp"
                android:text="Edit your profile information"
                android:textColor="#878787"
                android:textSize="15sp"
                android:textAlignment="center" />

            <TextView
                android:id="@+id/nameText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/statusText"
                android:layout_alignStart="@id/name"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="5dp"
                android:text="Full Name"
                android:textColor="#595959"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/nameText"
                android:minHeight="48dp"
                android:padding="12dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:ems="10"
                android:background="@drawable/edit_text_box"
                android:hint="enter your full name"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/dateOfbirthText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/name"
                android:layout_alignStart="@id/name"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="5dp"
                android:text="Date of Birth"
                android:textColor="#595959"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/dateOfBirth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/dateOfbirthText"
                android:minHeight="48dp"
                android:padding="12dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/edit_text_box"
                android:hint="select your date of birth"
                android:textSize="15sp"
                android:focusable="false"
                android:clickable="true"/>

            <TextView
                android:id="@+id/genderText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/dateOfBirth"
                android:layout_alignStart="@id/name"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="5dp"
                android:text="Gender"
                android:textColor="#595959"
                android:textSize="15sp"
                android:textStyle="bold" />

            <AutoCompleteTextView
                android:id="@+id/gender"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/genderText"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:minHeight="48dp"
                android:padding="12dp"
                android:background="@drawable/edit_text_box"
                android:hint="select gender"
                android:textSize="15sp"
                android:inputType="none"/>

            <TextView
                android:id="@+id/bloodText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/gender"
                android:layout_alignStart="@id/name"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="5dp"
                android:text="Blood Group"
                android:textColor="#595959"
                android:textSize="15sp"
                android:textStyle="bold" />

            <AutoCompleteTextView
                android:id="@+id/blood"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/bloodText"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:minHeight="48dp"
                android:padding="12dp"
                android:background="@drawable/edit_text_box"
                android:hint="select your blood group"
                android:textSize="15sp"
                android:inputType="none"/>

            <LinearLayout
                android:id="@+id/linearLayout2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_below="@+id/blood">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/weightText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:layout_marginLeft="20dp"
                        android:layout_marginRight="20dp"
                        android:layout_marginBottom="5dp"
                        android:text="Weight"
                        android:textColor="#595959"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/weight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:padding="12dp"
                        android:layout_marginStart="20dp"
                        android:layout_marginEnd="20dp"
                        android:background="@drawable/edit_text_box"
                        android:hint="kg"
                        android:textSize="15sp"
                        android:inputType="number"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/heightText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="5dp"
                        android:text="Height"
                        android:textColor="#595959"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/height"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/edit_text_box"
                        android:hint="cm"
                        android:inputType="number"
                        android:minHeight="48dp"
                        android:padding="12dp"
                        android:textSize="15sp" />
                </LinearLayout>

            </LinearLayout>


            <Button
                android:id="@+id/saveEdit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:layout_below="@id/linearLayout2"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="40dp"
                android:text="Save"
                android:backgroundTint="@color/black"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold" />



        </RelativeLayout>
    </ScrollView>
</RelativeLayout>